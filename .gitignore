# Working notes — never commit
.scratch/

# .NET secrets — never commit
appsettings.Production.json
appsettings.*.local.json
**/secrets.json
**/.env
**/.env.local

# OS / editor
.DS_Store
.idea/
*.swp

# Build outputs (per-project .gitignore covers more)
bin/
obj/
node_modules/

# Report PDF dump artifacts (CEREMONY_PDF_DUMP 校正輸出，本地檢視用)
output/

# Legacy reference source — local only, not committed
reference/old/

# DB backups — never commit (大檔 + 含 PII；本機保留即可)
*.bak
*.trn
reference/
