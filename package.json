{
  "name": "ceremony",
  "version": "1.0.0",
  "description": "法會報名系統 - Electron + Angular 21",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:electron": "tsc -p tsconfig.node.json",
    "electron:dev": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && npm run build:electron && electron .\"",
    "electron:build": "ng build --configuration production && npm run build:electron && electron-builder",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.2.3",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "dotenv": "^17.3.1",
    "electron-store": "^11.0.2",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.5.8",
    "handlebars": "^4.7.8",
    "knex": "^3.1.0",
    "mssql": "^12.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mssql": "^9.1.9",
    "concurrently": "^9.2.1",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.4"
  }
}
